App(
    appid="flipperfid_uhf",
    name="FlippeRFID UHF",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="flipper_rfid_app",
    cdefines=["APP_VERSION=\\\"0.1.0\\\""],
    requires=["gui", "storage"],
    stack_size=16 * 1024,
    fap_category="Tools",
    fap_description="Modular UHF EPC Gen2 app for multiple UART RFID readers",
    fap_author="Fernando García Villarroel",
)
